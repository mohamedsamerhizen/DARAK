# Production-safe example. Copy to an ignored .env file and replace every YOUR_* value outside source control.
ASPNETCORE_ENVIRONMENT=Production
SQLSERVER_DATABASE=DARAKDb
SQLSERVER_SA_PASSWORD=YOUR_STRONG_SQLSERVER_PASSWORD_HERE

JWT_ISSUER=DARAK.Api
JWT_AUDIENCE=DARAK.Api
JWT_SECRET_KEY=YOUR_64_PLUS_CHARACTER_PRODUCTION_JWT_SECRET_HERE
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

REGISTRATION_ENABLE_PUBLIC_REGISTRATION=false
REGISTRATION_AUTO_CONFIRM_REGISTERED_USERS=false

BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULLNAME=System Administrator

DEMO_SEED_ENABLED=false
DEMO_SEED_USERS=false
DEMO_SEED_PASSWORD=
DEMO_SEED_ALLOW_PRODUCTION=false

NOTIFICATIONS_WORKER_ENABLED=false
NOTIFICATIONS_EMAIL_ENABLED=false
NOTIFICATIONS_EMAIL_HOST=
NOTIFICATIONS_EMAIL_PORT=587
NOTIFICATIONS_EMAIL_ENABLE_SSL=true
NOTIFICATIONS_EMAIL_USERNAME=
NOTIFICATIONS_EMAIL_PASSWORD=
NOTIFICATIONS_EMAIL_FROM=
NOTIFICATIONS_SMS_ENABLED=false
NOTIFICATIONS_SMS_ENDPOINT_URL=
NOTIFICATIONS_SMS_API_KEY=
NOTIFICATIONS_SMS_SENDER_ID=DARAK
