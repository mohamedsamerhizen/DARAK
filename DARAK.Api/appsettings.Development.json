{
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_SQL_SERVER_CONNECTION_STRING_HERE"
  },
  "Jwt": {
    "Issuer": "DARAK.Api",
    "Audience": "DARAK.Api",
    "SecretKey": "YOUR_JWT_SECRET_KEY_HERE",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "Registration": {
    "EnablePublicRegistration": true,
    "AutoConfirmRegisteredUsers": true
  },
  "BootstrapAdmin": {
    "Enabled": false,
    "Email": "",
    "Password": "",
    "FullName": "Development SuperAdmin"
  },
  "DemoSeed": {
    "Enabled": false,
    "SeedUsers": true,
    "DemoPassword": "",
    "AllowProduction": false
  },
  "ZainCash": {
    "MerchantId": "YOUR_ZAINCASH_MERCHANT_ID_HERE",
    "Secret": "YOUR_ZAINCASH_SECRET_HERE"
  },
  "AllowedHosts": "*",
  "Payments": {
    "EnableMockGatewayEndpoints": false
  }
}
