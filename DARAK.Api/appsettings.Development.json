{
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_SQL_SERVER_CONNECTION_STRING_HERE"
  },
  "Jwt": {
    "Issuer": "DARAK.Api",
    "Audience": "DARAK.Api",
    "SecretKey": "YOUR_JWT_SECRET_KEY_HERE",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "DevelopmentSuperAdmin": {
    "Email": "YOUR_SUPERADMIN_EMAIL_HERE",
    "Password": "YOUR_SUPERADMIN_PASSWORD_HERE",
    "FullName": "Development SuperAdmin"
  },
  "ZainCash": {
    "MerchantId": "YOUR_ZAINCASH_MERCHANT_ID_HERE",
    "Secret": "YOUR_ZAINCASH_SECRET_HERE"
  },
  "AllowedHosts": "*",
  "Payments": {
    "EnableMockGatewayEndpoints": false
  }
}
