# Use Development for local Swagger. Set Production outside local development.
ASPNETCORE_ENVIRONMENT=Development
SQLSERVER_DATABASE=DARAKDb
SQLSERVER_SA_PASSWORD=YOUR_SQLSERVER_PASSWORD_HERE

JWT_ISSUER=DARAK.Api
JWT_AUDIENCE=DARAK.Api
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

DEVELOPMENT_SUPERADMIN_EMAIL=YOUR_SUPERADMIN_EMAIL_HERE
DEVELOPMENT_SUPERADMIN_PASSWORD=YOUR_SUPERADMIN_PASSWORD_HERE
DEVELOPMENT_SUPERADMIN_FULLNAME=Development SuperAdmin


# Optional real-ready notification delivery.
# Keep disabled unless real SMTP/SMS credentials are configured outside source control.
NOTIFICATIONS_WORKER_ENABLED=false
NOTIFICATIONS_EMAIL_ENABLED=false
NOTIFICATIONS_EMAIL_HOST=YOUR_SMTP_HOST_HERE
NOTIFICATIONS_EMAIL_PORT=587
NOTIFICATIONS_EMAIL_ENABLE_SSL=true
NOTIFICATIONS_EMAIL_USERNAME=YOUR_SMTP_USERNAME_HERE
NOTIFICATIONS_EMAIL_PASSWORD=YOUR_SMTP_PASSWORD_HERE
NOTIFICATIONS_EMAIL_FROM=notifications@example.com
NOTIFICATIONS_SMS_ENABLED=false
NOTIFICATIONS_SMS_ENDPOINT_URL=https://sms-provider.example/send
NOTIFICATIONS_SMS_API_KEY=YOUR_SMS_PROVIDER_API_KEY_HERE
NOTIFICATIONS_SMS_SENDER_ID=DARAK
